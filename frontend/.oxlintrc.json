{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "es2024": true
  },
  "ignorePatterns": ["coverage", "dist", "bindings", "node_modules"],
  "rules": {
    "no-console": "off",
    "no-underscore-dangle": ["warn", { "allow": ["__APP_VERSION__"] }],
    "react/react-in-jsx-scope": "off",
    "react/no-array-index-key": "off"
  }
}
